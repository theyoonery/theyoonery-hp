---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{SITE_TITLE}</title>
		<meta name="description" content={SITE_DESCRIPTION} />
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			html, body {
				height: 100%;
				overflow: hidden;
			}
			body {
				background: #0a0a0f;
				color: #e0e0e0;
				font-family: 'Courier New', 'Consolas', monospace;
			}

			#ascii-bg {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 0;
				overflow: hidden;
				white-space: pre;
				font-size: 14px;
				line-height: 16px;
				color: #1a1a2e;
				pointer-events: none;
				user-select: none;
			}

			#center-content {
				position: fixed;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				z-index: 1;
				text-align: center;
				pointer-events: auto;
			}

			#creature {
				white-space: pre;
				font-size: 16px;
				line-height: 1.2;
				color: #c0c0d0;
				cursor: pointer;
				transition: color 0.3s;
				display: inline-block;
				min-height: 120px;
			}

			#creature:hover {
				color: #ffffff;
			}

			#site-title {
				margin-top: 20px;
				font-size: 14px;
				letter-spacing: 0.3em;
				text-transform: lowercase;
				color: #555570;
				transition: color 0.5s;
			}

			#site-title:hover {
				color: #8888aa;
			}

			#hint {
				margin-top: 12px;
				font-size: 11px;
				color: #2a2a40;
				transition: opacity 0.5s;
			}
		</style>
	</head>
	<body>
		<div id="ascii-bg"></div>
		<div id="center-content">
			<div id="creature"></div>
			<div id="site-title">{SITE_TITLE}</div>
			<div id="hint">click me</div>
		</div>

		<script>
			// в”Җв”Җ ASCII Wave Background в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
			const bgEl = document.getElementById('ascii-bg');
			const chars = ' .В·:;+=*#%@';
			let cols = 0;
			let rows = 0;
			let mouseX = 0.5;
			let mouseY = 0.5;
			let time = 0;

			function measureGrid() {
				const testSpan = document.createElement('span');
				testSpan.textContent = 'M';
				testSpan.style.fontSize = '14px';
				testSpan.style.fontFamily = "'Courier New', Consolas, monospace";
				testSpan.style.position = 'absolute';
				testSpan.style.visibility = 'hidden';
				document.body.appendChild(testSpan);
				const charW = testSpan.offsetWidth;
				const charH = 16;
				document.body.removeChild(testSpan);
				cols = Math.ceil(window.innerWidth / charW) + 1;
				rows = Math.ceil(window.innerHeight / charH) + 1;
			}

			function renderBg() {
				time += 0.015;
				let out = '';
				for (let y = 0; y < rows; y++) {
					for (let x = 0; x < cols; x++) {
						const nx = x / cols;
						const ny = y / rows;

						// layered sine waves
						const wave1 = Math.sin(nx * 6 + time * 0.7) * Math.cos(ny * 4 + time * 0.5);
						const wave2 = Math.sin((nx + ny) * 5 + time * 0.3) * 0.5;
						const wave3 = Math.cos(nx * 3 - time * 0.6) * Math.sin(ny * 7 + time * 0.4) * 0.3;

						// mouse influence вҖ” gentle ripple
						const dx = nx - mouseX;
						const dy = ny - mouseY;
						const dist = Math.sqrt(dx * dx + dy * dy);
						const mouseWave = Math.sin(dist * 12 - time * 2) * Math.max(0, 0.5 - dist) * 0.8;

						const val = (wave1 + wave2 + wave3 + mouseWave + 1) / 3;
						const clamped = Math.max(0, Math.min(1, val));
						const idx = Math.floor(clamped * (chars.length - 1));
						out += chars[idx];
					}
					if (y < rows - 1) out += '\n';
				}
				bgEl.textContent = out;
				requestAnimationFrame(renderBg);
			}

			document.addEventListener('mousemove', (e) => {
				mouseX = e.clientX / window.innerWidth;
				mouseY = e.clientY / window.innerHeight;
			});

			window.addEventListener('resize', measureGrid);
			measureGrid();
			renderBg();

			// в”Җв”Җ Tamagotchi Creature в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
			const creatureEl = document.getElementById('creature');
			const hintEl = document.getElementById('hint');

			const frames = {
				idle: [
`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ вҖў  вҖў в”Ӯ
    в”Ӯ  в”Җв”Җ  в”Ӯ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
     /|  |\\
      в”Ӯ  в”Ӯ`,

`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ вҖў  вҖў в”Ӯ
    в”Ӯ  в”Җв”Җ  в”Ӯ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
    /в”Ӯ  в”Ӯ\\
     в”Ӯ  в”Ӯ`,
				],
				blink: [
`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ -  - в”Ӯ
    в”Ӯ  в”Җв”Җ  в”Ӯ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
     /|  |\\
      в”Ӯ  в”Ӯ`,
				],
				happy: [
`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ ^  ^ в”Ӯ
    в”Ӯ  в—Ўв—Ў  в”Ӯ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
    \\в”Ӯ  в”Ӯ/
     в”Ӯ  в”Ӯ`,

`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ ^  ^ в”Ӯ
    в”Ӯ  в—Ўв—Ў  в”Ӯ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
   \\в”Ӯв”Ӯ  в”Ӯв”Ӯ/
     в”Ӯ  в”Ӯ`,
				],
				wave: [
`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ вҖў  вҖў в”Ӯ   /
    в”Ӯ  в—Ўв—Ў  в”Ӯв”Җв”Җ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
     /|
      в”Ӯ  в”Ӯ`,

`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ вҖў  вҖў в”Ӯ  в”Җ
    в”Ӯ  в—Ўв—Ў  в”Ӯв”Җв”Җ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
     /|
      в”Ӯ  в”Ӯ`,

`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ вҖў  вҖў в”Ӯ   \\
    в”Ӯ  в—Ўв—Ў  в”Ӯв”Җв”Җ
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ
     /|
      в”Ӯ  в”Ӯ`,
				],
				sleep: [
`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ -  - в”Ӯ  z
    в”Ӯ  в”Җв”Җ  в”Ӯ   z
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ    z
     /|  |\\
      в”Ӯ  в”Ӯ`,

`    в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв•®
    в”Ӯ -  - в”Ӯ
    в”Ӯ  в”Җв”Җ  в”Ӯ  z
    в•°в”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ   z
     /|  |\\
      в”Ӯ  в”Ӯ`,
				],
			};

			let currentAnim = 'idle';
			let frameIdx = 0;
			let tickCount = 0;
			let isInteracting = false;
			let idleTicks = 0;
			let sleeping = false;

			function tick() {
				tickCount++;
				idleTicks++;

				// blink randomly during idle
				if (currentAnim === 'idle' && !isInteracting) {
					if (Math.random() < 0.05) {
						currentAnim = 'blink';
						frameIdx = 0;
						setTimeout(() => {
							if (currentAnim === 'blink') {
								currentAnim = 'idle';
								frameIdx = 0;
							}
						}, 200);
					}
				}

				// fall asleep after ~20 seconds of no interaction
				if (idleTicks > 100 && !sleeping && !isInteracting) {
					sleeping = true;
					currentAnim = 'sleep';
					frameIdx = 0;
				}

				const animFrames = frames[currentAnim];
				frameIdx = (frameIdx + 1) % animFrames.length;
				creatureEl.textContent = animFrames[frameIdx];
			}

			setInterval(tick, 200);

			// click to make it happy
			creatureEl.addEventListener('click', () => {
				isInteracting = true;
				idleTicks = 0;
				sleeping = false;
				hintEl.style.opacity = '0';

				const reactions = ['happy', 'wave'];
				currentAnim = reactions[Math.floor(Math.random() * reactions.length)];
				frameIdx = 0;

				setTimeout(() => {
					currentAnim = 'idle';
					frameIdx = 0;
					isInteracting = false;
				}, 2000);
			});

			// wake up on mouse enter
			creatureEl.addEventListener('mouseenter', () => {
				if (sleeping) {
					sleeping = false;
					idleTicks = 0;
					currentAnim = 'blink';
					frameIdx = 0;
					setTimeout(() => {
						currentAnim = 'idle';
						frameIdx = 0;
					}, 400);
				}
			});

			// initial render
			creatureEl.textContent = frames.idle[0];
		</script>
	</body>
</html>
